# Environment: development | production
FLASK_ENV=production

# Server (bind to 127.0.0.1 for local-only; 0.0.0.0 for LAN access on shop network)
HOST=127.0.0.1
PORT=5000
THREADS=4

# Security — generate a unique key per installation
# SECRET_KEY=your-64-char-hex-secret-here

# Vendor license signing secret (change before commercial distribution)
LICENSE_SECRET=GSM-VENDOR-SECRET-2026-CHANGE-ME

# Session
SESSION_HOURS=12
SESSION_COOKIE_SECURE=false

# Operations
AUTO_BACKUP_ON_START=true
LOG_LEVEL=INFO